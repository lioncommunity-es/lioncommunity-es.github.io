---
import ToolLayout from "@layouts/ToolLayout.astro";
---

<ToolLayout
  title="Generador de Contraseñas"
  description="Crea contraseñas seguras y personalizables con control de longitud, caracteres especiales y entropía."
  icon="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
>
  <div class="space-y-6">
    <!-- Generated password display -->
    <div
      class="rounded-2xl border border-white/6 bg-white/3 p-6"
    >
      <label class="mb-2 block text-xs font-medium text-white/40">
        Contraseña generada
      </label>
      <div class="flex items-center gap-3">
        <div
          id="password-display"
          class="flex-1 overflow-x-auto rounded-xl border border-white/10 bg-surface-700 px-4 py-3 font-mono text-lg tracking-wider text-orange-300 select-all"
        >
          —
        </div>
        <button
          id="copy-btn"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-white/50 transition-all hover:border-orange-500/30 hover:bg-orange-500/10 hover:text-orange-400"
          title="Copiar"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />
          </svg>
        </button>
        <button
          id="generate-btn"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-orange-500 text-white shadow-lg shadow-orange-500/20 transition-all hover:bg-orange-600 hover:shadow-orange-500/30 active:scale-95"
          title="Generar nueva"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
          </svg>
        </button>
      </div>

      <!-- Strength meter -->
      <div class="mt-4">
        <div class="mb-1.5 flex items-center justify-between">
          <span class="text-[11px] text-white/30">Seguridad</span>
          <span id="strength-label" class="text-[11px] font-medium text-white/40">—</span>
        </div>
        <div class="h-1.5 overflow-hidden rounded-full bg-white/5">
          <div id="strength-bar" class="h-full w-0 rounded-full transition-all duration-500"></div>
        </div>
        <div class="mt-1.5 flex items-center justify-between">
          <span id="entropy-value" class="text-[11px] text-white/20 font-mono">0 bits de entropía</span>
          <span id="crack-time" class="text-[11px] text-white/20">—</span>
        </div>
      </div>
    </div>

    <!-- Options -->
    <div class="grid gap-4 sm:grid-cols-2">
      <!-- Length -->
      <div class="rounded-2xl border border-white/6 bg-white/3 p-5 sm:col-span-2">
        <div class="mb-3 flex items-center justify-between">
          <label for="length-range" class="text-xs font-medium text-white/60">Longitud</label>
          <span id="length-value" class="rounded-lg bg-surface-600 px-2.5 py-0.5 font-mono text-xs text-orange-400">16</span>
        </div>
        <input
          id="length-range"
          type="range"
          min="4"
          max="128"
          value="16"
          class="w-full cursor-pointer accent-orange-500"
        />
        <div class="mt-1 flex justify-between text-[10px] text-white/20">
          <span>4</span>
          <span>128</span>
        </div>
      </div>

      <!-- Toggle options -->
      <div class="rounded-2xl border border-white/6 bg-white/3 p-5">
        <h3 class="mb-4 text-xs font-semibold tracking-wide text-white/50 uppercase">Caracteres</h3>
        <div class="space-y-3">
          <label class="flex cursor-pointer items-center justify-between">
            <span class="text-sm text-white/70">Mayúsculas <span class="text-white/30 font-mono text-xs">(A-Z)</span></span>
            <input type="checkbox" id="opt-upper" checked class="h-4 w-4 rounded accent-orange-500" />
          </label>
          <label class="flex cursor-pointer items-center justify-between">
            <span class="text-sm text-white/70">Minúsculas <span class="text-white/30 font-mono text-xs">(a-z)</span></span>
            <input type="checkbox" id="opt-lower" checked class="h-4 w-4 rounded accent-orange-500" />
          </label>
          <label class="flex cursor-pointer items-center justify-between">
            <span class="text-sm text-white/70">Números <span class="text-white/30 font-mono text-xs">(0-9)</span></span>
            <input type="checkbox" id="opt-numbers" checked class="h-4 w-4 rounded accent-orange-500" />
          </label>
          <label class="flex cursor-pointer items-center justify-between">
            <span class="text-sm text-white/70">Símbolos <span class="text-white/30 font-mono text-xs">(!@#$...)</span></span>
            <input type="checkbox" id="opt-symbols" checked class="h-4 w-4 rounded accent-orange-500" />
          </label>
        </div>
      </div>

      <!-- Extra options -->
      <div class="rounded-2xl border border-white/6 bg-white/3 p-5">
        <h3 class="mb-4 text-xs font-semibold tracking-wide text-white/50 uppercase">Opciones</h3>
        <div class="space-y-3">
          <label class="flex cursor-pointer items-center justify-between">
            <span class="text-sm text-white/70">Excluir ambiguos <span class="text-white/30 font-mono text-xs">(0Ol1I)</span></span>
            <input type="checkbox" id="opt-no-ambiguous" class="h-4 w-4 rounded accent-orange-500" />
          </label>
          <label class="flex cursor-pointer items-center justify-between">
            <span class="text-sm text-white/70">Empezar con letra</span>
            <input type="checkbox" id="opt-start-letter" class="h-4 w-4 rounded accent-orange-500" />
          </label>
        </div>

        <!-- Batch generate -->
        <div class="mt-5 border-t border-white/5 pt-4">
          <label class="mb-2 block text-xs font-medium text-white/40">Generar múltiples</label>
          <div class="flex gap-2">
            <input
              id="batch-count"
              type="number"
              min="1"
              max="50"
              value="1"
              class="w-20 rounded-lg border border-white/10 bg-surface-600 px-3 py-2 text-xs text-white outline-none focus:border-orange-500/40"
            />
            <button
              id="batch-btn"
              class="rounded-lg border border-orange-500/20 bg-orange-500/10 px-4 py-2 text-xs font-medium text-orange-400 transition-all hover:border-orange-500/40 hover:bg-orange-500/20"
            >
              Generar lote
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Batch output -->
    <div id="batch-output" class="hidden rounded-2xl border border-white/6 bg-white/3 p-5">
      <div class="mb-3 flex items-center justify-between">
        <h3 class="text-xs font-semibold tracking-wide text-white/50 uppercase">Lote generado</h3>
        <button id="copy-batch" class="text-[11px] text-orange-400/70 transition-colors hover:text-orange-400">
          Copiar todo
        </button>
      </div>
      <pre id="batch-list" class="max-h-60 overflow-y-auto rounded-xl bg-surface-700 p-4 font-mono text-xs leading-relaxed text-white/60"></pre>
    </div>
  </div>

  <script>
    const UPPER = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const LOWER = "abcdefghijklmnopqrstuvwxyz";
    const NUMBERS = "0123456789";
    const SYMBOLS = "!@#$%^&*()_+-=[]{}|;:,.<>?~";
    const AMBIGUOUS = "0Ol1I";

    const display = document.getElementById("password-display")!;
    const lengthRange = document.getElementById("length-range") as HTMLInputElement;
    const lengthValue = document.getElementById("length-value")!;
    const generateBtn = document.getElementById("generate-btn")!;
    const copyBtn = document.getElementById("copy-btn")!;
    const strengthBar = document.getElementById("strength-bar")!;
    const strengthLabel = document.getElementById("strength-label")!;
    const entropyValue = document.getElementById("entropy-value")!;
    const crackTime = document.getElementById("crack-time")!;
    const batchBtn = document.getElementById("batch-btn")!;
    const batchCount = document.getElementById("batch-count") as HTMLInputElement;
    const batchOutput = document.getElementById("batch-output")!;
    const batchList = document.getElementById("batch-list")!;
    const copyBatch = document.getElementById("copy-batch")!;

    function getCharset() {
      let charset = "";
      if ((document.getElementById("opt-upper") as HTMLInputElement).checked) charset += UPPER;
      if ((document.getElementById("opt-lower") as HTMLInputElement).checked) charset += LOWER;
      if ((document.getElementById("opt-numbers") as HTMLInputElement).checked) charset += NUMBERS;
      if ((document.getElementById("opt-symbols") as HTMLInputElement).checked) charset += SYMBOLS;

      if ((document.getElementById("opt-no-ambiguous") as HTMLInputElement).checked) {
        charset = charset.split("").filter(c => !AMBIGUOUS.includes(c)).join("");
      }

      return charset;
    }

    function generate(): string {
      const charset = getCharset();
      if (!charset) return "Selecciona al menos un tipo";

      const len = parseInt(lengthRange.value);
      const arr = new Uint32Array(len);
      crypto.getRandomValues(arr);

      let password = Array.from(arr).map(n => charset[n % charset.length]).join("");

      if ((document.getElementById("opt-start-letter") as HTMLInputElement).checked) {
        const letters = charset.split("").filter(c => /[a-zA-Z]/.test(c));
        if (letters.length) {
          const rnd = new Uint32Array(1);
          crypto.getRandomValues(rnd);
          password = letters[rnd[0] % letters.length] + password.slice(1);
        }
      }

      return password;
    }

    function updateStrength(password: string) {
      const charset = getCharset();
      if (!charset || password.startsWith("Selecciona")) {
        strengthBar.style.width = "0";
        strengthLabel.textContent = "—";
        entropyValue.textContent = "0 bits de entropía";
        crackTime.textContent = "—";
        return;
      }

      const entropy = Math.log2(charset.length) * password.length;
      entropyValue.textContent = `${entropy.toFixed(1)} bits de entropía`;

      let pct: number, label: string, color: string;
      if (entropy < 28) { pct = 10; label = "Muy débil"; color = "#ef4444"; }
      else if (entropy < 36) { pct = 25; label = "Débil"; color = "#f97316"; }
      else if (entropy < 60) { pct = 50; label = "Aceptable"; color = "#eab308"; }
      else if (entropy < 80) { pct = 75; label = "Fuerte"; color = "#22c55e"; }
      else { pct = 100; label = "Muy fuerte"; color = "#10b981"; }

      strengthBar.style.width = pct + "%";
      strengthBar.style.backgroundColor = color;
      strengthLabel.textContent = label;
      strengthLabel.style.color = color;

      // Crack time estimate (10 billion guesses/sec)
      const combos = Math.pow(charset.length, password.length);
      const seconds = combos / 1e10 / 2;
      if (seconds < 1) crackTime.textContent = "< 1 segundo";
      else if (seconds < 60) crackTime.textContent = `~${Math.ceil(seconds)} segundos`;
      else if (seconds < 3600) crackTime.textContent = `~${Math.ceil(seconds / 60)} minutos`;
      else if (seconds < 86400) crackTime.textContent = `~${Math.ceil(seconds / 3600)} horas`;
      else if (seconds < 3.154e7) crackTime.textContent = `~${Math.ceil(seconds / 86400)} días`;
      else if (seconds < 3.154e9) crackTime.textContent = `~${Math.ceil(seconds / 3.154e7)} años`;
      else crackTime.textContent = `~${(seconds / 3.154e7).toExponential(1)} años`;
    }

    function doGenerate() {
      const pw = generate();
      display.textContent = pw;
      updateStrength(pw);
    }

    lengthRange.addEventListener("input", () => {
      lengthValue.textContent = lengthRange.value;
      doGenerate();
    });

    generateBtn.addEventListener("click", doGenerate);

    copyBtn.addEventListener("click", async () => {
      const text = display.textContent || "";
      await navigator.clipboard.writeText(text);
      copyBtn.innerHTML = '<svg class="h-4 w-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>';
      setTimeout(() => {
        copyBtn.innerHTML = '<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" /></svg>';
      }, 1500);
    });

    document.querySelectorAll("input[type=checkbox]").forEach(cb => {
      cb.addEventListener("change", doGenerate);
    });

    batchBtn.addEventListener("click", () => {
      const count = Math.min(50, Math.max(1, parseInt(batchCount.value) || 1));
      const passwords = Array.from({ length: count }, () => generate());
      batchList.textContent = passwords.join("\n");
      batchOutput.classList.remove("hidden");
    });

    copyBatch.addEventListener("click", async () => {
      await navigator.clipboard.writeText(batchList.textContent || "");
      copyBatch.textContent = "¡Copiado!";
      setTimeout(() => { copyBatch.textContent = "Copiar todo"; }, 1500);
    });

    // Initial generation
    doGenerate();
  </script>
</ToolLayout>
