---
import "@styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lion Community — Dev Tools",
  description = "Herramientas de desarrollo para la comunidad Lion Community. Utilidades, generadores y recursos para programadores.",
} = Astro.props;
---

<html lang="es" class="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1a1a1a" />

    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="min-h-screen bg-surface-900 font-sans text-white antialiased selection:bg-orange-500/30"
  >
    <slot />
  </body>
</html>
