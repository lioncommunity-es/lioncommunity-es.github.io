---

<section id="tools" class="relative pb-24">
    <div class="mx-auto max-w-7xl px-6">
        <!-- Section header -->
        <div class="mb-10 flex items-end justify-between">
            <div>
                <h2
                    class="text-lg font-semibold tracking-tight text-white/90 sm:text-xl">
                    Herramientas
                </h2>
                <p class="mt-1 text-sm text-white/40">
                    Selecciona una herramienta para empezar
                </p>
            </div>
            <span
                class="hidden text-xs font-medium text-white/30 tabular-nums sm:block">
                {tools.filter((t) => !t.comingSoon).length} disponibles
            </span>
        </div>

        <!-- Grid -->
        <div
            id="tools-grid"
            class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
            {
                tools.map((tool, index) => (
                    <div
                        class="animate-slide-up"
                        style={`animation-delay: ${0.05 + index * 0.05}s;`}>
                        <ToolCard {...tool} />
                    </div>
                ))
            }
        </div>

        <!-- Empty state for search -->
        <div
            id="empty-state"
            class="mt-16 hidden flex-col items-center justify-center text-center">
            <svg
                class="mb-4 h-12 w-12 text-white/10"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1">
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <p class="text-sm text-white/30">
                No se encontraron herramientas para tu búsqueda.
            </p>
        </div>
    </div>
</section>

<script>
    const searchInput = document.getElementById(
        "tool-search",
    ) as HTMLInputElement;
    const cards = document.querySelectorAll("[data-tool-card]");
    const gridContainer = document.getElementById("tools-grid");
    const emptyState = document.getElementById("empty-state");

    searchInput?.addEventListener("input", () => {
        const query = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;

        cards.forEach((card) => {
            const wrapper = card.parentElement as HTMLElement;
            const title = card.getAttribute("data-title") || "";
            const matches = query === "" || title.includes(query);

            wrapper.style.display = matches ? "" : "none";
            if (matches) visibleCount++;
        });

        if (emptyState) {
            emptyState.style.display = visibleCount === 0 ? "flex" : "none";
        }
    });
</script>
