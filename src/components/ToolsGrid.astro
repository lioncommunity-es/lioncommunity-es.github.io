        icon: "M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5",
    },
    {
        title: "Conversor Base64",
        description:
            "Codifica y decodifica texto y archivos a/desde Base64 de forma rápida y sencilla.",
