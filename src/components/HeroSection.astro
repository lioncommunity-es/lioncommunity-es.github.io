---
/**
 * HeroSection — Top area with title, description, and a decorative glow.
 */
---

<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
    <!-- Background decorative elements -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <!-- Orange glow -->
        <div
            class="animate-pulse-glow absolute top-1/4 -left-1/4 h-96 w-96 rounded-full bg-orange-500/8 blur-3xl">
        </div>
        <div
            class="animate-pulse-glow absolute top-1/3 -right-1/4 h-80 w-80 rounded-full bg-orange-600/5 blur-3xl"
            style="animation-delay: 1.5s;">
        </div>
        <!-- Dot grid -->
        <div
            class="absolute inset-0 opacity-[0.03]"
            style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;">
        </div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6">
        <!-- Badge -->
        <div class="animate-slide-up mb-8 flex justify-center">
            <div
                class="inline-flex items-center gap-2 rounded-full border border-orange-500/20 bg-orange-500/5 px-4 py-1.5">
                <span class="relative flex h-2 w-2">
                    <span
                        class="absolute inline-flex h-full w-full animate-ping rounded-full bg-orange-400 opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex h-2 w-2 rounded-full bg-orange-500"
                    ></span>
                </span>
                <span
                    class="text-xs font-medium tracking-wide text-orange-300/90">
                    Herramientas para desarrolladores
                </span>
            </div>
        </div>

        <!-- Heading -->
        <h1
            class="animate-slide-up stagger-2 mx-auto max-w-3xl text-center text-4xl leading-tight font-bold tracking-tight sm:text-5xl lg:text-6xl">
            <span class="text-white">Tu caja de</span>
            <br />
            <span
                class="bg-linear-to-r from-orange-400 via-orange-500 to-orange-600 bg-clip-text text-transparent">
                herramientas dev
            </span>
        </h1>

        <!-- Description -->
        <p
            class="animate-slide-up stagger-3 mx-auto mt-6 max-w-xl text-center text-base leading-relaxed text-white/50 sm:text-lg">
            Utilidades, generadores y recursos pensados para agilizar tu flujo
            de trabajo como programador.
        </p>

        <!-- Search (decorative / future) -->
        <div class="animate-slide-up stagger-4 mx-auto mt-10 max-w-md">
            <div class="relative">
                <svg
                    class="pointer-events-none absolute top-1/2 left-4 h-4 w-4 -translate-y-1/2 text-white/30"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <input
                    id="tool-search"
                    type="text"
                    placeholder="Buscar herramienta..."
                    class="w-full rounded-xl border border-white/10 bg-white/5 py-3 pr-4 pl-11 text-sm text-white placeholder-white/30 transition-all duration-300 outline-none focus:border-orange-500/40 focus:bg-white/[0.07] focus:ring-1 focus:ring-orange-500/20"
                />
            </div>
        </div>
    </div>
</section>
